# Nerve — Environment Variables
# Copy to .env and fill in your values.
# Used by Docker for non-interactive setup.

# Authentication (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_CODE_OAUTH_TOKEN=                # OAuth token (Pro/Max subscription — from `claude setup-token` or host extraction)

# Optional
OPENAI_API_KEY=
GH_TOKEN=                              # GitHub token (from `gh auth token` or host extraction)
NERVE_MODE=personal
NERVE_TIMEZONE=America/New_York
